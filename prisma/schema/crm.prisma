model Customer {
  id           String             @id
  tenantId     String
  companyName  String
  segment      String?
  customerType String             @default("PRIVATE")
  taxOffice    String?
  taxNumber    String?
  address      String?
  mainPhone    String?
  mobilePhone  String?
  mainEmail    String?
  website      String?
  language     String?
  vatNumber    String?
  customerSource String?
  responsibleFirstName String?
  responsibleLastName  String?
  status       String             @default("ACTIVE")
  isActive     Boolean            @default(true)
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  activities   CustomerActivity[]
  contacts     CustomerContact[]
  notes        CustomerNote[]
  locations    CustomerLocation[]
  tenders      Tender[]
  projects     Project[]
  appointments Appointment[]
  offerScheduleSlots OfferScheduleSlot[]
  shipments Shipment[]
  maintenanceContracts MaintenanceContract[]
  serviceCalls ServiceCall[]
  workOrders WorkOrder[]
  salesOrders SalesOrder[]
  invoices Invoice[]

  @@index([tenantId], map: "Customer_tenantId_fkey")
}

model SalesOrder {
  id                  String   @id
  tenantId            String
  customerId          String?
  tenderId            String?  @unique
  projectId           String?
  parentSalesOrderId  String?
  revisionNumber      Int?
  orderNumber         String
  orderType           String
  status              String   @default("ORDERED")
  totalAmount         Float    @default(0)
  createdByEmployeeId String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  // Business date shown to the user. For addon (Zusatzauftrag) orders this is the
  // original appointment date the extra work belongs to, which may predate createdAt
  // when the entry is made days later. createdAt stays the internal "unbilled since"
  // slice boundary; orderDate is display-only. Null falls back to createdAt.
  orderDate           DateTime?

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  customer  Customer? @relation(fields: [customerId], references: [id])
  tender    Tender?   @relation(fields: [tenderId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])
  parentSalesOrder SalesOrder? @relation("SalesOrderAddons", fields: [parentSalesOrderId], references: [id])
  addonSalesOrders SalesOrder[] @relation("SalesOrderAddons")
  createdBy Employee  @relation(fields: [createdByEmployeeId], references: [id])
  reports   ProjectReport[]
  expenses  ProjectExpense[]
  appointments Appointment[]
  extraMaterials ProjectExtraMaterial[]
  invoices Invoice[]

  @@index([tenantId])
  @@index([customerId])
  @@index([projectId])
  @@index([parentSalesOrderId])
  @@index([createdByEmployeeId])
}

model CustomerContact {
  id               String   @id
  customerId       String
  firstName        String
  lastName         String
  title            String?
  phone            String?
  mobilePhone      String?
  email            String?
  notes            String?  @db.Text
  isPrimaryContact Boolean  @default(false)
  customer         Customer @relation(fields: [customerId], references: [id])

  @@index([customerId], map: "CustomerContact_customerId_fkey")
}

model CustomerNote {
  id                  String    @id
  customerId          String
  createdByEmployeeId String
  noteText            String    @db.Text
  noteType            String
  isHighlight         Boolean   @default(false)
  firstName           String?
  email               String?
  telephone           String?
  dateActivity        DateTime?
  createdAt           DateTime  @default(now())
  createdBy           Employee  @relation(fields: [createdByEmployeeId], references: [id])
  customer            Customer  @relation(fields: [customerId], references: [id])

  @@index([createdByEmployeeId], map: "CustomerNote_createdByEmployeeId_fkey")
  @@index([customerId], map: "CustomerNote_customerId_fkey")
}

model Document {
  id                   String   @id
  tenantId             String
  relatedEntityId      String
  entityType           String
  fileName             String
  fileUrl              String   @db.LongText
  fileType             String
  category             String?
  uploadedByEmployeeId String
  uploadedBy           Employee @relation(fields: [uploadedByEmployeeId], references: [id])

  @@index([uploadedByEmployeeId], map: "Document_uploadedByEmployeeId_fkey")
}

model CustomerActivity {
  id           String   @id
  customerId   String
  employeeId   String
  activityType String
  description  String?  @db.Text
  activityDate DateTime @default(now())
  referenceId  String?
  customer     Customer @relation(fields: [customerId], references: [id])

  @@index([customerId], map: "CustomerActivity_customerId_fkey")
}

model CustomerLocation {
  id            String   @id
  customerId    String
  name          String
  // Address list this entry belongs to: INSTALLATION (Montage/Lieferung) or BILLING (Rechnung).
  kind          String   @default("INSTALLATION")
  address       String?
  city          String?
  postalCode    String?
  country       String?
  phone         String?
  email         String?
  contactPerson String?
  isPrimary     Boolean  @default(false)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id])

  @@index([customerId], map: "CustomerLocation_customerId_fkey")
}
