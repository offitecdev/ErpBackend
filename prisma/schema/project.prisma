enum ProjectStatus {
  AWAITING_APPROVAL
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum AppointmentStatus {
  AVAILABLE
  BOOKED
  COMPLETED
  CANCELLED
}

model Project {
  id            String        @id
  tenantId      String
  customerId    String
  tenderId      String?       @unique
  managerId     String?
  projectName   String
  status        ProjectStatus @default(AWAITING_APPROVAL)
  plannedBudget Float         @default(0)
  actualCost    Float         @default(0)
  overtimeHourlyRate Float     @default(0)
  overtimeTolerancePercent Float @default(15)

  startDate DateTime?
  endDate   DateTime?

  bookingToken String? @unique @db.VarChar(128)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  tender   Tender?   @relation(fields: [tenderId], references: [id])
  manager  Employee? @relation("ProjectManager", fields: [managerId], references: [id])

  phases            ProjectPhase[]
  reports           ProjectReport[]
  expenses          ProjectExpense[]
  appointments      Appointment[]
  projectVariations ProjectVariation[]
  extraMaterials    ProjectExtraMaterial[]
  shipments         Shipment[]
  salesOrders       SalesOrder[]
  invoices          Invoice[]

  @@index([tenantId])
  @@index([customerId])
}

model ProjectPhase {
  id                 String  @id
  projectId          String
  phaseName          String
  progressPercentage Float   @default(0)
  isCompleted        Boolean @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

