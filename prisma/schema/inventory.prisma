enum LocationType {
  MAIN_WAREHOUSE
  SUB_WAREHOUSE
  STATION_BUFFER
  PROJECT_RESERVE
}

enum MovementType {
  IN
  OUT
  TRANSFER
  RETURN
  ADJUSTMENT
}

enum ProposalStatus {
  PENDING
  APPROVED
  CONVERTED
  REJECTED
}

model Location {
  id               String       @id
  tenantId         String
  parentLocationId String?
  locationName     String
  locationType     LocationType
  isActive         Boolean      @default(true)

  tenant         Tenant     @relation(fields: [tenantId], references: [id])
  parentLocation Location?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id])
  subLocations   Location[] @relation("LocationHierarchy")

  balances        StockBalance[]
  movementsSource StockMovement[] @relation("SourceLocation")
  movementsDest   StockMovement[] @relation("DestLocation")
  articleSuppliers ArticleSupplier[]

  @@index([tenantId])
  @@index([parentLocationId])
}

model StockBalance {
  id               String   @id
  tenantId         String
  articleId        String
  locationId       String
  currentQuantity  Float    @default(0)
  reservedQuantity Float    @default(0)
  updatedAt        DateTime @updatedAt

  article  Article  @relation(fields: [articleId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([articleId, locationId])
  @@index([tenantId])
}

model StockMovement {
  id                    String       @id
  tenantId              String
  articleId             String
  movementType          MovementType
  quantity              Float
  unitCost              Float? // Manuel girişlerde bu partinin birim maliyeti (ağırlıklı ortalama için)
  sourceLocationId      String?
  destinationLocationId String?
  transactionDate       DateTime     @default(now())
  employeeId            String
  referenceId           String? // Proje ID, İhale ID veya Üretim Emri ID
  description           String?      @db.Text

  article             Article   @relation(fields: [articleId], references: [id])
  sourceLocation      Location? @relation("SourceLocation", fields: [sourceLocationId], references: [id])
  destinationLocation Location? @relation("DestLocation", fields: [destinationLocationId], references: [id])
  employee            Employee  @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([articleId])
  @@index([employeeId])
}

model PurchaseProposal {
  id               String         @id
  tenantId         String
  articleId        String
  proposedQuantity Float
  supplierId       String? // İleride Supplier tablosu gelince bağlanabilir
  status           ProposalStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  resolvedAt       DateTime?
  resolvedByEmpId  String?

  article    Article   @relation(fields: [articleId], references: [id])
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  resolvedBy Employee? @relation(fields: [resolvedByEmpId], references: [id])

  @@index([tenantId])
  @@index([articleId])
  @@index([supplierId])
}

model Supplier {
  id             String   @id
  tenantId       String
  companyName    String
  contactName    String?
  email          String?
  phone          String?
  address        String?  @db.Text
  notes          String?  @db.Text
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  articleSuppliers  ArticleSupplier[]
  purchaseProposals PurchaseProposal[]

  @@unique([tenantId, companyName])
  @@index([tenantId])
}

model ArticleSupplier {
  id               String   @id
  tenantId         String
  articleId        String
  supplierId       String
  locationId       String?
  supplierSku      String?
  purchasePrice    Float    @default(0)
  quantity         Float    @default(0)
  remainingQuantity Float  @default(0)
  currency         String   @default("CHF")
  lastPurchaseDate DateTime?
  stockMovementId  String?
  notes            String?  @db.Text
  isPreferred      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  article  Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id])

  @@index([tenantId])
  @@index([articleId])
  @@index([supplierId])
  @@index([locationId])
}
