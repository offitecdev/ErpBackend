{
  "name": "erp_backend",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node main.js",
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json",
    "postinstall": "node -e \"const fs=require('fs'),path=require('path'),cp=require('child_process');const roots=[process.env.OFFITEC_APP_ROOT,process.env.INIT_CWD,process.cwd()].filter(Boolean);const root=roots.find((item)=>fs.existsSync(path.join(item,'prisma','schema')));if(!root){console.log('[OFFITEC] Prisma schema bulunamadi; postinstall generate atlandi.');process.exit(0)}cp.execFileSync(process.execPath,[require.resolve('prisma/build/index.js'),'generate','--schema',path.join(root,'prisma','schema')],{cwd:root,stdio:'inherit',env:process.env});\"",
    "prisma:generate": "prisma generate --schema prisma/schema",
    "dev": "ts-node-dev --respawn src/main.ts",
    "swagger": "ts-node swagger.ts",
    "generate:swagger": "ts-node scripts/export-swagger.ts",
    "seed": "ts-node prisma/seed.ts",
    "sees": "npm run seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-mariadb": "7.7.0",
    "@prisma/client": "7.7.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.2",
    "morgan": "^1.10.1",
    "nanoid": "^3.3.11",
    "prisma": "7.7.0",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
